{
  "name": "psl-init",
  "version": "1.0.0",
  "description": "Generate PSL.md for your project — Product Spec Language",
  "type": "module",
  "bin": {
    "psl-init": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "pslSpecVersion": "1",
  "keywords": [
    "psl",
    "product-spec-language",
    "naming-convention",
    "vocabulary",
    "ai-agents",
    "specification"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fliptables/psl.git",
    "directory": "cli"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ignore": "^6.0.0"
  }
}
