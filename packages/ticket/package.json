{
  "name": "psl-ticket",
  "version": "1.0.0",
  "description": "Generate PSL-tagged tickets from natural language",
  "type": "module",
  "bin": {
    "psl-ticket": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fliptables/psl.git",
    "directory": "packages/ticket"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "@psl/core": "*",
    "@anthropic-ai/sdk": "^0.52.0",
    "commander": "^12.0.0"
  }
}
